@article{Nielsen20233191,
  author            = {Nielsen, Kristin and Hendeby, Gustaf},
  title             = {Multi-Hypothesis SLAM for Non-Static Environments With Reoccurring Landmarks},
  year              = {2023},
  journal           = {IEEE Transactions on Intelligent Vehicles},
  volume            = {8},
  number            = {4},
  pages             = {3191 - 3203},
  doi               = {10.1109/TIV.2022.3214978},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85140724731&doi=10.1109%2FTIV.2022.3214978&partnerID=40&md5=e764cf533885b52744779f958dce988f},
  abstract          = {A static world assumption is often used when considering the simultaneous localization and mapping (SLAM) problem. In reality, especially when long-term autonomy is the objective, this is not valid. This paper studies a scenario where uniquely identifiable landmarks can attend multiple discrete positions, not known a priori. Based on a feature based multi-hypothesis map representation, a multi-hypothesis SLAM algorithm is developed inspired by target tracking theory. The creation of such a map is merged into the SLAM framework allowing any available SLAM method to solve the underlying mapping and localization problem for each hypothesis. A recursively updated hypothesis score allows for hypothesis rejection and prevents exponential growth in the number of hypotheses. The developed method is evaluated in an underground mine application, where physical barriers can be moved in between multiple distinct positions. Simulations are conducted in this environment showing the benefits of the multi-hypothesis approach compared to executing a standard SLAM algorithm. Practical considerations as well as suitable approximations are elaborated upon and experiments on real data further validates the simulated results and show that the multi-hypothesis approach has similar performance in reality as in simulation. © 2016 IEEE.},
  author_keywords   = {multi-hypothesis; non-static environment; SLAM},
  keywords          = {Clutter (information theory); Decision making; Mapping; Robotics; Target tracking; Decisions makings; Location awareness; Multi-hypothesis; Non-static environment; Simultaneous localization and mapping; Simultaneous localization and mapping</italic>; Static environment; Targets tracking; Vehicle's dynamics; Markov processes},
  publication_stage = {Final},
  note              = {All Open Access; Green Accepted Open Access; Green Open Access}
}

@article{Deng202336,
  author            = {Deng, Tianchen and Xie, Hongle and Wang, Jingchuan and Chen, Weidong},
  title             = {Long-Term Visual Simultaneous Localization and Mapping: Using a Bayesian Persistence Filter-Based Global Map Prediction},
  year              = {2023},
  journal           = {IEEE Robotics and Automation Magazine},
  volume            = {30},
  number            = {1},
  pages             = {36 - 49},
  doi               = {10.1109/MRA.2022.3228492},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85147216103&doi=10.1109%2FMRA.2022.3228492&partnerID=40&md5=a0d9c594adf6faa0570d40531ffeb680},
  abstract          = {With the rapidly growing demand for accurate localization in real-world environments, visual simultaneous localization and mapping (SLAM) has received significant attention in recent years. However, those existing methods still suffer from the degradation of localization accuracy in long-term changing environments. To address these problems, we propose a novel long-term SLAM system with map prediction and dynamics removal. First, a visual point-cloud matching algorithm is designed to efficiently fuse 2D pixel information and 3D voxel information. Second, each map point is classified into three types: static, semistatic, and dynamic based on the Bayesian persistence filter (BPF). Then we remove the dynamic map points to eliminate the influence of those map points. We can obtain a global predicted map by modeling the time series of semistatic map points. Finally, we incorporate the predicted global map into a state-of-the-art SLAM method, achieving an efficient visual SLAM system for long-term, dynamic environments. Extensive experiments are carried out on a wheelchair robot in an indoor environment over several months. The results demonstrate that our method has better map prediction accuracy and achieves more robust localization performance. © 1994-2011 IEEE.},
  keywords          = {Forecasting; Indoor positioning systems; Mapping; Robotics; Time series analysis; Bayesian; Filter-based; Global map; Growing demand; Localisation Systems; Location awareness; Mapping systems; Simultaneous localization and mapping; Time-series analysis; Visual simultaneous localization and mappings; Bandpass filters},
  publication_stage = {Final}
}

@article{Cheng20233926,
  author            = {Cheng, Ruiqi and Li, Jian and Guo, Fei and Hao, Zihuan and Wu, Jieqiong and Yang, Dongqing},
  title             = {A Map Construction and Maintenance Framework for Long-term Navigation Based on LiDAR},
  year              = {2023},
  journal           = {IET Conference Proceedings},
  volume            = {2023},
  number            = {47},
  pages             = {3926 - 3933},
  doi               = {10.1049/icp.2024.1740},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85203133111&doi=10.1049%2Ficp.2024.1740&partnerID=40&md5=dd1cf23ab4321313ba171af3f6f473e1},
  abstract          = {We propose a method for constructing and maintaining a navigation map in dynamic environments using laser scan information. During long-term robot operation, changes in environmental information are unavoidable. Accurate map construction and real-time map updates are crucial for ensuring reliable autonomous navigation over an extended period. Moreover, the dynamic environmental information in the global map can adversely affect the accuracy of LiDAR-based simultaneous localization and mapping algorithms. Given the sparsity of real-time laser scan data in comparison to previous maps, this paper presents a map construction algorithm and a map update algorithm that utilize obstacle-level segmentation. These algorithms demonstrate improved noise filtering capabilities and dynamic information detection, thereby ensuring the accuracy and reliability of the navigation map. We evaluated our approach through experiments conducted in both virtual simulation and real-world physical environments. The results demonstrate its effectiveness in enhancing map construction and map update performance, as well as providing reliable map information for autonomous robot navigation. © The Institution of Engineering & Technology 2023.},
  author_keywords   = {DYNAMIC ENVIRONMENT; LIDAR SENSOR; MAP CONSTRUCTION AND MAINTENANCE; ROBOT NAVIGATION},
  keywords          = {Image segmentation; Laser applications; Mapping; Network security; Robots; Dynamic environments; Environmental information; Laser scans; LIDAR sensors; MAP CONSTRUCTION AND MAINTENANCE; Map constructions; Navigation map; Real- time; Robot navigation; Robot operations; Optical radar},
  publication_stage = {Final}
}

@conference{Yu2023764,
  author            = {Yu, Naigong and Wang, Yang and Gan, Mengzhe and Ma, Nan and Huang, Gao},
  title             = {Lifelong SLAM Based on Environmental Semantic and Depth Information in Dynamic Scenes},
  year              = {2023},
  journal           = {Proceedings of 2023 7th Asian Conference on Artificial Intelligence Technology, ACAIT 2023},
  pages             = {764 - 770},
  doi               = {10.1109/ACAIT60137.2023.10528652},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85194190440&doi=10.1109%2FACAIT60137.2023.10528652&partnerID=40&md5=7de8618bbd48d5e88a84cbf54d4dedf7},
  abstract          = {The Simultaneous Localization and Mapping (SLAM) algorithm is robust enough when used on static scenes. However, it is less robust when used in dynamic scenes where objects move for an extended period in indoor scenes. In order to address the mentioned issues, this paper proposes an indoor dynamic scene localization and map construction algorithm that combines environmental semantic with depth information. Based on the ORB-SLAM2 framework: First, we perform semantic segmentation on keyframes to obtain the mask, then we combine the mask and optical flow algorithm to estimate the motion properties of environmental objects and remove dynamic features. Second, keyframe pose, semantic label, and depth information are combined to identify scene loop. Finally, we filter the keyframes twice and construct a static semantic map. We conducted experiments in a dynamic simulation environment and TUM dataset. The result shows that the proposed algorithm can maintain high localization and loop detection accuracy in dynamic scenes, and the static semantic map can reliably describe the scene, reflecting better lifelong localization robustness. © 2023 IEEE.},
  author_keywords   = {dynamic scene; semantic segmentation; static semantic map; visual SLAM},
  keywords          = {Indoor positioning systems; Robotics; Semantic Segmentation; Depth information; Dynamic scenes; Key-frames; Localisation; Semantic map; Semantic segmentation; Simultaneous localization and mapping; Static semantic map; Static semantics; Visual simultaneous localization and mappings; Semantics},
  publication_stage = {Final}
}

@conference{Oh20231904,
  author            = {Oh, Sang-hyeon and Hwan, Kwak Dong and Lim, Hyun Tek},
  title             = {2.5D SLAM Algorithm with Novel Data Fusion Method Between 2D-Lidar and Camera},
  year              = {2023},
  journal           = {International Conference on Control, Automation and Systems},
  pages             = {1904 - 1907},
  doi               = {10.23919/ICCAS59377.2023.10316979},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85179182193&doi=10.23919%2FICCAS59377.2023.10316979&partnerID=40&md5=e2495159e280fb821b388f1ff26ec7a4},
  abstract          = {The SLAM algorithm has been extensively researched and has gained significant relevance in our daily lives, particularly with the advancements in robot technology and autonomous driving. Currently, SLAM can be largely divided into 2D SLAM and 3D SLAM. In the case of 2D SLAM, accurate mapping and localization of the plane can be achieved with low computational requirements. However, it has the limitation of not considering 3D information. In contrast, 3D SLAM can generate maps and perform localization in complex indoor spaces with obstacles by incorporating 3D data on objects. However, it may face challenges in real-time implementation in embedded systems due to high computational demands. In this paper, we propose a 2.5D SLAM using the Life Long Feature(LLF) algorithm. First, 2.5D SLAM is a projection of 3D camera feature points that are not perceived by the 2D-Lidar onto the 2D-Lidar plane. The transformation matrix to project camera feature to 2D-Lidar plane is calculated by optimizing least-square problem of the same points recognized by the camera and 2D-Lidar. Additionally, the LLF algorithm enables the updating and maintenance of camera feature points based on the robot's current position, even when the camera is not perceiving objects. The difference in Field Of View(FOV) between the camera and the LiDAR causes the problem of being recognized as a dynamic object and removing feature points. The LLF algorithm can solve this problem even when the object is within the range of the 2D-LiDAR but not visible in the camera's FOV. In experiment, we confirmed our proposed 2.5D SLAM with LLF algorithm show better performance in detecting 3D objects and Mapping than pervious 2D SLAM. © 2023 ICROS.},
  author_keywords   = {2.5D SLAM; Sensor Fusion; SLAM; Visual SLAM},
  keywords          = {Embedded systems; Indoor positioning systems; Linear transformations; Mapping; Object detection; Optical radar; Real time control; Sensor data fusion; 2.5d SLAM; Autonomous driving; Daily lives; Data fusion methods; Field of views; Robot technology; Sensor fusion; SLAM; SLAM algorithm; Visual SLAM; Cameras},
  publication_stage = {Final}
}

@article{Bouaziz2023350,
  author            = {Bouaziz, Youssef and Royer, Eric and Bresson, Guillaume and Dhome, Michel},
  title             = {A Uniform Distribution of Landmarks for Efficient Map Compression},
  year              = {2023},
  journal           = {Lecture Notes in Computer Science (including subseries Lecture Notes in Artificial Intelligence and Lecture Notes in Bioinformatics)},
  volume            = {14253 LNCS},
  pages             = {350 - 362},
  doi               = {10.1007/978-3-031-44137-0_29},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85174540807&doi=10.1007%2F978-3-031-44137-0_29&partnerID=40&md5=cacf1ed75ea7b91c5804271529a6d5ce},
  abstract          = {In this paper, we address the challenge of visual-based localization in dynamic outdoor environments characterized by continuous appearance changes. These changes greatly affect the visual information of the scene, resulting in significant performance degradation in visual localization. The issue arises from the difficulty of mapping data between the current image and the landmarks on the map due to environmental variations. One approach to tackle this problem is continuously adding new landmarks to the map to accommodate diverse environmental conditions. However, this leads to map growth, which in turn incurs high costs and resource demands for localization. To address this, we propose a map management approach based on an extension of the state-of-the-art technique called Summary Maps. Our approach employs a scoring policy that assigns scores to landmarks based on their appearance in multiple localization sessions. Consequently, landmarks observed in multiple sessions are assigned higher scores. We demonstrate the necessity of maintaining landmark diversity throughout map compression to ensure reliable long-term localization. To evaluate our approach, we conducted experiments on a dataset comprising over 100 sequences encompassing various environmental conditions. The obtained results were compared with those of the state-of-the-art approach, showcasing the effectiveness and superiority of our proposed method. © The Author(s), under exclusive license to Springer Nature Switzerland AG 2023.},
  author_keywords   = {Computer Vision for Transportation; Long-Term SLAM; Visual-Based Navigation},
  keywords          = {Robotics; Computer vision for transportation; Environmental conditions; Localisation; Long-term SLAM; Outdoor environment; Performance degradation; Uniform distribution; Visual information; Visual localization; Visual-based navigation; Computer vision},
  publication_stage = {Final}
}

@article{Wang2023,
  author            = {Wang, Xuanzhi and Sun, Yankang and Xie, Yuyang and Bin, Jiang and Xiao, Jian},
  title             = {Deep reinforcement learning-aided autonomous navigation with landmark generators},
  year              = {2023},
  journal           = {Frontiers in Neurorobotics},
  volume            = {17},
  pages             = {},
  doi               = {10.3389/fnbot.2023.1200214},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85169703112&doi=10.3389%2Ffnbot.2023.1200214&partnerID=40&md5=3241d5903d64d2fe8c6ea68df6174fcd},
  abstract          = {Mobile robots are playing an increasingly significant role in social life and industrial production, such as searching and rescuing robots, autonomous exploration of sweeping robots, and so on. Improving the accuracy of autonomous navigation of mobile robots is a hot issue to be solved. However, traditional navigation methods are unable to realize crash-free navigation in an environment with dynamic obstacles, more and more scholars are gradually using autonomous navigation based on deep reinforcement learning (DRL) to replace overly conservative traditional methods. But on the other hand, DRL's training time is too long, and the lack of long-term memory easily leads the robot to a dead end, which makes its application in the actual scene more difficult. To shorten training time and prevent mobile robots from getting stuck and spinning around, we design a new robot autonomous navigation framework which combines the traditional global planning and the local planning based on DRL. Therefore, the entire navigation process can be transformed into first using traditional navigation algorithms to find the global path, then searching for several high-value landmarks on the global path, and then using the DRL algorithm to move the mobile robot toward the designated landmarks to complete the final navigation, which makes the robot training difficulty greatly reduced. Furthermore, in order to improve the lack of long-term memory in deep reinforcement learning, we design a feature extraction network containing memory modules to preserve the long-term dependence of input features. Through comparing our methods with traditional navigation methods and reinforcement learning based on end-to-end depth navigation methods, it shows that while the number of dynamic obstacles is large and obstacles are rapidly moving, our proposed method is, on average, 20% better than the second ranked method in navigation efficiency (navigation time and navigation paths' length), 34% better than the second ranked method in safety (collision times), 26.6% higher than the second ranked method in success rate, and shows strong robustness. © © 2023 Wang, Sun, Xie, Bin and Xiao.},
  author_keywords   = {autonomous navigation; deep reinforcement learning (DRL); mobile robots; simultaneous localization and mapping; trajectory planning},
  keywords          = {Deep learning; Learning systems; Machine design; Navigation; Reinforcement learning; Robot programming; Autonomous navigation; Deep reinforcement learning; Dynamic obstacles; Long term memory; Navigation methods; Reinforcement learnings; Simultaneous localization and mapping; Social life; Training time; Trajectory Planning; Mobile robots; algorithm; anatomic landmark; Article; autonomous navigation; computer simulation; conservative treatment; decision making; deep learning; environment; feature extraction; histogram; human; learning; long term memory; mathematical model; memory; nerve cell network; reinforcement learning (machine learning); robotics; social life; training},
  publication_stage = {Final},
  note              = {All Open Access; Gold Open Access; Green Accepted Open Access; Green Open Access}
}

@conference{Mahmoud2023185,
  author            = {Mahmoud, Jaafar and Penkovskiy, Andrey},
  title             = {Dynamic Environments and Robust SLAM: Optimizing Sensor Fusion and Semantics for Wheeled Robots},
  year              = {2023},
  journal           = {Conference of Open Innovation Association, FRUCT},
  volume            = {2023-May},
  pages             = {185 - 191},
  doi               = {10.23919/FRUCT58615.2023.10143050},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85162853984&doi=10.23919%2FFRUCT58615.2023.10143050&partnerID=40&md5=7ddfec5999cc6acdeb9276632130af7c},
  abstract          = {This paper proposes an approach to enhance the robustness and accuracy of visual simultaneous localization and mapping (SLAM) for ground wheeled mobile robots in dynamic environments. The proposed method incorporates encoder measurements to establish optimization constraints in bundle adjustment. To further improve robustness, a geometric technique utilizing KMeans clustering with epipolar constraints and the SegNet [1] for semantic segmentation is employed to filter out features detected on moving objects. These modifications are integrated into the state-of-the-art SLAM system ORB-SLAM3 [2] and demonstrate superior accuracy and real-time performance compared to the baseline approach. The effectiveness of the proposed method is demonstrated through multiple OpenLoris and IROS Lifelong SLAM competition scenarios. © 2023 FRUCT.},
  keywords          = {Object detection; Semantic Segmentation; Semantics; Bundle adjustments; Dynamic environments; Encoder measurements; Geometric techniques; K-means++ clustering; Optimisation constraints; Sensor fusion; Simultaneous localization and mapping; Visual simultaneous localization and mappings; Wheeled robot; Mobile robots},
  publication_stage = {Final},
  note              = {All Open Access; Green Accepted Open Access; Green Open Access}
}

@conference{Vega-Torres2023567,
  author            = {Vega-Torres, Miguel A. and Braun, Alexander and Borrmann, André},
  title             = {OGM2PGBM: Robust BIM-based 2D-LiDAR localization for lifelong indoor navigation},
  year              = {2023},
  journal           = {eWork and eBusiness in Architecture, Engineering and Construction - Proceedings of the 14th European Conference on Product and Process Modelling, ECPPM 2022},
  pages             = {567 - 574},
  doi               = {10.1201/9781003354222-72},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85160435493&doi=10.1201%2F9781003354222-72&partnerID=40&md5=22d96a20a22d2319c8b676a237cee953},
  abstract          = {Several studies rely on particle filter (PF) algorithms for robot localization in Occupancy Grid Maps (OGMs) extracted from building information models (BIM models). However, most ignore the possible discrepancies between the reference model and the real world (Scan-BIM deviations). These deviations affect the accuracy of PF drastically. This paper proposes an open-source method to generate appropriate Pose Graph-based maps from BIM models for robust 2D-LiDAR localization in changing and dynamic environments. First, 2D OGMs are generated from complex BIM models allowing autonomous navigation. Then, a technique converts these maps into Pose Graph-based maps enabling accurate pose tracking. Finally, a robust localization is proposed with a combination of state-of-the-art algorithms. We found that Pose Graph-based algorithms are four times more accurate than PF algorithms by tracking the robot’s pose in a real environment. The proposed method contributes to a robust localization with a BIM model in changing and dynamic environments. © 2023 the Author(s).},
  keywords          = {Architectural design; Graphic methods; Optical radar; Robot applications; Building Information Modelling; Changing environment; Dynamic environments; Graph-based; Indoor navigation; Localisation; Occupancy grid map; Particle filter algorithms; Reference modeling; Robot localization; Indoor positioning systems},
  publication_stage = {Final},
  note              = {All Open Access; Green Accepted Open Access; Green Open Access}
}

@article{Wang2023149,
  author            = {Wang, Huyue and Wang, Kevin I.Kai},
  title             = {A Standalone Millimeter-Wave SLAM System for Indoor Search and Rescue},
  year              = {2023},
  journal           = {Lecture Notes in Electrical Engineering},
  volume            = {1035 LNEE},
  pages             = {149 - 161},
  doi               = {10.1007/978-3-031-29871-4_17},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85159386806&doi=10.1007%2F978-3-031-29871-4_17&partnerID=40&md5=77e844c25ed872f2f44c2c7e840eeec4},
  abstract          = {Real-time location data offers great insight to achieve many intelligent and context-aware applications, such as personalised location-aware services, navigation, surveillance, and search and rescue. While outdoor location can be easily collected by the global positioning system (GPS), indoor location data remains challenging to collect and faces several challenges such as cost, pre-configured infrastructures, and limited long-term accuracy. In this study, a novel Simultaneous Localization and Mapping (SLAM) system is proposed and implemented targeting indoor search and rescue application, using the state-of-the-art millimeter-wave (mmWave) radar sensor. The proposed system is completely self-contained and requires no prior installation or configuration of any other devices. A 2-dimensional map and movement trajectory data is produced as the output of the SLAM system. Typical straight line and L-shape pathway experiments have been conducted. In both cases, the proposed system is capable of achieving submeter accuracy, which are promising results demonstrating its ability to provide accurate SLAM for indoor applications. © 2023, The Author(s), under exclusive license to Springer Nature Switzerland AG.},
  author_keywords   = {Indoor navigation; indoor positioning; millimeter-wave; Simultaneous Localization and Mapping (SLAM)},
  keywords          = {Global positioning system; Indoor positioning systems; Location; Mapping; Robotics; Search engines; Context aware applications; Indoor navigation; Indoor positioning; Localisation Systems; Location data; Mapping systems; Real-time location; Search and rescue; Simultaneous localization and mapping; Millimeter waves},
  publication_stage = {Final}
}

@conference{Arshad2023371,
  author            = {Arshad, Saba and Kim, Gon-woo},
  title             = {Leveraging Semantics in Appearance based Loop Closure Detection for Long-Term Visual SLAM},
  year              = {2023},
  journal           = {Proceedings - 2023 IEEE International Conference on Big Data and Smart Computing, BigComp 2023},
  pages             = {371 - 372},
  doi               = {10.1109/BigComp57234.2023.00087},
  url               = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85151555339&doi=10.1109%2FBigComp57234.2023.00087&partnerID=40&md5=472d8e0d5e92a5a9c4eb74e4143c5461},
  abstract          = {In simultaneous localization and mapping, the detection of true loop closure benefits in relocalization and increased map accuracy. However, its performance is largely affected by variation in light conditions, viewpoints, seasons, and presence of dynamic objects. Focusing the advantages of visual semantics, this research proposes a semantics aided bag-of-wordsmodel overcoming the limitations of conventional BoW model which performs appearance-based loop detection and has been gold standard for many years. The proposed method reduces the computation time while matching current frame with the database image by segmenting the search space. Further it enhances the true loop detection rate. © 2023 IEEE.},
  author_keywords   = {long term autonomy; semantic labels; visual loop closure detection; visual navigation.},
  keywords          = {Robotics; Appearance based; Long term autonomy; Loop closure; Loop detection; Semantic labels; Simultaneous localization and mapping; Visual loop closure detection; Visual Navigation; Visual navigation.; Visual SLAM; Semantics},
  publication_stage = {Final}
}


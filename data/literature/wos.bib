Title = {Efficient 2D LIDAR-Based Map Updating For Long-Term Operations in
   Dynamic Environments},
Booktitle = {2022 IEEE/RSJ INTERNATIONAL CONFERENCE ON INTELLIGENT ROBOTS AND SYSTEMS
   (IROS)},

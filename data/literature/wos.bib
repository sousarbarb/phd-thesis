   Peng, Hongrui; Zhao, Ziyu; Wang, Liguan, Cent South Univ, Sch Resources \& Safety Engn, Changsha 410083, Peoples R China.
   Wang, Liguan, Changsha Digital Mine Co Ltd, Changsha 410221, Peoples R China.},
DOI = {10.3390/s24020645},

Title = {Energy-Efficient SLAM via Joint Design of Sensing, Communication, and
   Exploration Speed},
Booktitle = {IEEE INFOCOM 2025-IEEE CONFERENCE ON COMPUTER COMMUNICATIONS WORKSHOPS,
   INFOCOM WKSHPS},
Series = {IEEE Conference on Computer Communications Workshops},
Year = {2025},
Note = {2025 Conference on Computer Communications-INFOCOM-Annual, London,
   ENGLAND, MAY 19-22, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {Lifelong simultaneous localization and mapping (SLAM) has garnered
   significant attention in the context of supporting advanced spatial
   machine intelligence applications. Typically, SLAM is implemented
   through various mobile robots that continuously perform concurrent
   sensing and communication in dynamic environment. This paper focuses on
   analyzing the energy efficiency of robot operation for lifelong SLAM by
   jointly considering sensing, communication, and mechanical factors. The
   system model is built based on a robot equipped with a two-dimensional
   light detection and ranging (2D LiDAR) and an odometry. The raw cloud
   point data along with the odometry data is wirelessly transmitted to a
   data center, where real-time map reconstruction is performed utilizing
   an unsupervised deep learning-based approach. The sensing time duration
   of LiDAR, the transmit power and time duration of communication, and the
   exploration speed of robot are jointly optimized to minimize energy
   consumption. Simulations and experiments demonstrate the effectiveness
   of our proposed method.},

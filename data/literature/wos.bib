@article{ WOS:001512879600003,
Author = {Liu, Jiayi and Jin, Xiang and Ji, Yao and Ba, Jinxing and Fan,
   Shuangshuang},
Title = {Underwater glider persistent coverage using deep reinforcement learning
   for ocean observation},
Journal = {OCEAN ENGINEERING},
Year = {2025},
Volume = {336},
Month = {SEP 1},
Abstract = {Ocean dynamic processes play a key role in the transport of matter and
   energy and influence the interaction between the atmosphere and the
   ocean. Due to their significant spatiotemporal variability, long-term,
   high-resolution observation is crucial. However, existing observation
   methods (such as anchored buoys and drifting buoys) have limitations in
   coverage and operational continuity, making it difficult to meet
   persistent observation needs. To address these challenges, this paper
   proposes a deep reinforcement learning-based method for achieving
   persistent coverage in specific areas using underwater gliders (UGs),
   with particular consideration of ocean current impacts. In formulating
   this problem, we simplify the UG kinematic model to a two-dimensional
   horizontal plane and discretize the observation area into cells,
   transforming the persistent coverage problem into a discrete cells
   coverage problem. This approach reduces computational complexity while
   maintaining effective path optimization. Our proposed method utilizes
   the Proximal Policy Optimization (PPO) algorithm, allowing UGs to
   autonomously learn the currents and generate optimal paths for
   persistent coverage by interacting with the environment. We design a
   revisit cycle map to quantify coverage rate and introduce a reward
   function to enhance the effectiveness and persistence of coverage. In
   addition, a set of metrics is defined to evaluate path performance for
   persistent coverage. Simulation results using both virtual flow fields
   and real-world ocean currents demonstrate that our method exhibits
   desired adaptability and achieves stable coverage performance across
   various ocean environments. While the method shows promising results, it
   requires retraining when deployed in unknown environments. In addition,
   our future work should address practical considerations including UG
   localization precision, the actual mobility of the UG, and the influence
   of complex currents.},

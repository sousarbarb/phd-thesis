  <!-- <arg name="logfile" default="/home/ros1noetic/ros_ws/test/flowbotic_20251027.tum" /> -->
  <!-- <arg name="logfile" default="/home/ros1noetic/ros_ws/test/flowbotic_20251028.tum" /> -->

  <arg name="logfile" default="/home/ros1noetic/ros_ws/test/iilabs3d_nav_a_diff.tum" />
  <!-- <arg name="logfile" default="/home/ros1noetic/ros_ws/test/iilabs3d_nav_a_omni.tum" /> -->
  <!-- <arg name="logfile" default="/home/ros1noetic/ros_ws/test/iilabs3d_loop.tum" /> -->
  <!-- <arg name="logfile" default="/home/ros1noetic/ros_ws/test/iilabs3d_slippage.tum" /> -->

  <!-- <arg name="logfile" default="/home/ros1noetic/ros_ws/test/cappero.tum" /> -->

  <!-- <arg name="logfile" default="/home/ros1noetic/ros_ws/test/kuka.tum" /> -->



  <!-- <arg name="paramfile" default="slam_toolbox_avantgarde.yaml" /> -->
  <!-- <arg name="paramfile" default="slam_toolbox_flowbotic.yaml" /> -->
  <arg name="paramfile" default="slam_toolbox_iilabs3d.yaml" />
  <!-- <arg name="paramfile" default="slam_toolbox_cappero.yaml" /> -->
  <!-- <arg name="paramfile" default="slam_toolbox_kuka.yaml" /> -->





  <param name="/use_sim_time" value="true" />





  <node pkg="rviz" type="rviz" name="rviz"
        clear_params="true" output="screen"
        args="-d $(dirname)/slam_toolbox.rviz"/>

  <node pkg="slam_toolbox" type="sync_slam_toolbox_node"
    name="slam_toolbox"
    output="screen">

    <remap from="/map" to="map" />
    <remap from="/map_metadata" to="map_metadata" />

    <rosparam command="load" file="$(dirname)/$(arg paramfile)" subst_value="true" />

  </node>

  <node pkg="rosbag" type="record" name="record" output="screen"
    args="--quiet --repeat-latched -O $(arg logfile)_slam_toolbox.bag $(arg scan_topic) /tf /tf_static /slam_toolbox/pose" />

  <node pkg="rosbag" type="play" name="play" output="screen"
    args="--clock --quiet --start $(arg start) --rate $(arg rate) --delay 5 $(arg bagfiles)" />

</launch>
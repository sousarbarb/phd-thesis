  <!-- <arg name="bagsdir" default="/home/datasets/paper_slam_2d/slam/flowbotic"/> -->

  <!-- <arg name="bagfiles" default="$(arg bagsdir)/20251024/log_filtered_2025-10-24-13-54.bag"/> -->

  <arg name="paramfile" default="slam_kuka.yaml" />

  <node pkg="inesctec_mrdt_slam_distmap_2d_ros" type="slam_offline"
        name="slam_offline"
        clear_params="true" output="screen"
        args="-b $(arg bagfiles)
          --odomtopic $(arg odom_topic)
          --scantopic $(arg scan_topic)
          --start $(arg start)
          --log $(arg logfile)">

    <rosparam command="load" file="$(dirname)/$(arg paramfile)" subst_value="true" />

  </node>

</launch>
